REDIS_ENABLED=false
TOKEN_VERIFICATION_ENABLED=false

# Credentials for allowing user access
AUTH_CODE_CLIENT_ID=hmpps-typescript-template
AUTH_CODE_CLIENT_SECRET=clientsecret

# Credentials for API calls
CLIENT_CREDS_CLIENT_ID=esupervision-ui
CLIENT_CREDS_CLIENT_SECRET=

# user roles required to access the practitioner dashboard
# comma-separated list of allowed roles e.g.
# AUTHORISED_USER_ROLES=ROLE_ESUPERVISION__PRACTITIONER__RW
# leave empty to disable role check
AUTHORISED_USER_ROLES=
# user roles required to access the invite-pop dashboard
# comma-separated list of allowed roles e.g.
# INVITE_POP_USER_ROLES=ROLE_ESUPERVISION__PRACTITIONER__INVITE_POP
# leave empty to disable role check
INVITE_POP_USER_ROLES=

# TEMPORARY: when 'true', invite-pop access is restricted to the HMPPS usernames listed in
# INVITE_POP_ALLOWED_USERNAMES instead of the roles mentioned in INVITE_POP_USER_ROLES. Set to 'false' to use
# INVITE_POP_USER_ROLES again.
INVITE_POP_RESTRICT_BY_USERNAME=false
# comma-separated list of HMPPS usernames allowed to access invite-pop when the above is 'true'
# INVITE_POP_ALLOWED_USERNAMES=JBLOGGS,JSMITH
INVITE_POP_ALLOWED_USERNAMES=
