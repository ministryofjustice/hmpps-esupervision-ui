{% macro pduMatrixTable(params) %}
  {% set title = params.title %}
  {% set totalStats = params.totalStats %}
  {% set pduStats = params.pduStats %}
  {% set rows = params.rows %}
  {% set ariaLabel = params.ariaLabel or title %}

  <h2 class="govuk-heading-m govuk-!-margin-bottom-2">{{ title }}</h2>

  <div class="moj-scrollable-pane" role="region" aria-label="{{ ariaLabel }}" tabindex="0">
    <table class="govuk-table esup-matrix">
      <thead class="govuk-table__head">
        <tr class="govuk-table__row">
          <th scope="col" class="govuk-table__header esup-matrix__question-col">
            <span class="govuk-visually-hidden">Question</span>
          </th>

          <th scope="col" class="govuk-table__header esup-matrix__group" colspan="2">Total</th>
          <th class="esup-matrix__spacer" aria-hidden="true"></th>

          {% for pdu in pduStats %}
            <th scope="col" class="govuk-table__header esup-matrix__group" colspan="2">{{ pdu.pduDescription }}</th>
            {% if not loop.last %}
              <th class="esup-matrix__spacer" aria-hidden="true"></th>
            {% endif %}
          {% endfor %}
        </tr>

        <tr class="govuk-table__row esup-matrix__subhead">
          <th scope="col" class="govuk-table__header esup-matrix__question-col"></th>
          <th scope="col" class="govuk-table__header esup-matrix__minihead">No.</th>
          <th scope="col" class="govuk-table__header esup-matrix__minihead">%</th>
          <th class="esup-matrix__spacer" aria-hidden="true"></th>

          {% for pdu in pduStats %}
            <th scope="col" class="govuk-table__header esup-matrix__minihead">No.</th>
            <th scope="col" class="govuk-table__header esup-matrix__minihead">%</th>
            {% if not loop.last %}
              <th class="esup-matrix__spacer" aria-hidden="true"></th>
            {% endif %}
          {% endfor %}
        </tr>
      </thead>

      <tbody class="govuk-table__body">
        {% for row in rows %}
          {% set valueKey = row.valueKey %}
          {% set pctKey = row.pctKey %}
          {% set hoursAndMinutes = row.hoursAndMinutes %}

          <tr class="govuk-table__row">
            <th scope="row" class="govuk-table__header esup-matrix__rowhead">
              {{ row.label | safe }}
            </th>

            <td class="govuk-table__cell esup-matrix__num">
              {% if hoursAndMinutes %}
                {{ totalStats[valueKey] | hoursToHoursAndMinutes }}
              {% else %}
                {{ totalStats[valueKey] }}
              {% endif %}
            </td>

            <td class="govuk-table__cell esup-matrix__pct">
              {% if pctKey %}
                {{ totalStats[pctKey] | percentage(2) }}
              {% else %}
                —
              {% endif %}
            </td>

            <td class="esup-matrix__spacer" aria-hidden="true"></td>

            {% for pdu in pduStats %}
              <td class="govuk-table__cell esup-matrix__num">
                {% if hoursAndMinutes %}
                  {{ pdu[valueKey] | hoursToHoursAndMinutes }}
                {% else %}
                  {{ pdu[valueKey] }}
                {% endif %}
              </td>

              <td class="govuk-table__cell esup-matrix__pct">
                {% if pctKey %}
                  {{ pdu[pctKey] | percentage(2) }}
                {% else %}
                  —
                {% endif %}
              </td>

              {% if not loop.last %}
                <td class="esup-matrix__spacer" aria-hidden="true"></td>
              {% endif %}
            {% endfor %}
          </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
{% endmacro %}
